# Use glob syntax
syntax: glob

# Node modules (dependencies installed via npm)
node_modules/

# Environment files (sensitive data)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Build / dist folders
dist/
build/

# IDE / editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Database / local files
*.sqlite
*.db

# Coverage reports
coverage/